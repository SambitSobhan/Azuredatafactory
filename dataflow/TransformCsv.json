{
	"name": "TransformCsv",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "dataflowtransformation",
						"type": "DatasetReference"
					},
					"name": "sourcecsv"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "dataflowsink",
						"type": "DatasetReference"
					},
					"name": "sink"
				},
				{
					"dataset": {
						"referenceName": "sinkmastercard",
						"type": "DatasetReference"
					},
					"name": "sinkmastercard"
				},
				{
					"dataset": {
						"referenceName": "sinkother",
						"type": "DatasetReference"
					},
					"name": "sinkother"
				}
			],
			"transformations": [
				{
					"name": "selectcolumn"
				},
				{
					"name": "fiterid"
				},
				{
					"name": "splitcondition"
				},
				{
					"name": "derivedColumn"
				},
				{
					"name": "aggregatecustomerid"
				},
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          transaction_id as short,",
				"          transactional_date as timestamp,",
				"          product_id as string,",
				"          customer_id as short,",
				"          payment as string,",
				"          credit_card as long,",
				"          loyalty_card as boolean,",
				"          cost as double,",
				"          quantity as short,",
				"          price as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourcecsv",
				"sourcecsv select(mapColumn(",
				"          transaction_id,",
				"          transactional_date,",
				"          product_id,",
				"          customer_id,",
				"          payment,",
				"          cost,",
				"          quantity,",
				"          price",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectcolumn",
				"selectcolumn filter(customer_id !=12) ~> fiterid",
				"fiterid split(payment =='visa',",
				"     payment =='mastercard',",
				"     disjoint: false) ~> splitcondition@(visa, mastercard, otherthanvisa)",
				"splitcondition@otherthanvisa derive(payment = coalesce(payment,'N/A')) ~> derivedColumn",
				"splitcondition@visa aggregate(groupBy(customer_id),",
				"     product_id = max(product_id)) ~> aggregatecustomerid",
				"aggregatecustomerid alterRow(insertIf(1==1)) ~> alterRow1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink",
				"splitcondition@mastercard sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkmastercard",
				"derivedColumn sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkother"
			]
		}
	}
}